# Finboard environment (copy to repo root as `.env`)

NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:4000,http://127.0.0.1:4000
MONGODB_URI=mongodb://127.0.0.1:27017/kyc-auth-db
BANK_DATABASE_URL=postgresql://postgres:password@localhost:5432/finboard_banking
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
UPLOAD_DIR=uploads
MISTRAL_API_KEY=
MISTRAL_TEXT_MODEL=mistral-small-latest
MISTRAL_VISION_MODEL=pixtral-12b-latest
MISTRAL_OCR_MODEL=mistral-ocr-latest
# Powers OCR extraction and AI KYC verification scoring in admin review
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_VISION_MODEL=openai/gpt-4o-mini
LLM_MAX_TOKENS=256
INTERNAL_SERVICE_KEY=dev-internal-key

# Resend (email + OTP delivery) — leave blank for dev console fallback
RESEND_API_KEY=
RESEND_FROM=Finboard <onboarding@resend.dev>
OTP_TTL_MINUTES=5
PASSWORD_RESET_OTP_TTL_MINUTES=10

# Service URLs (api-gateway + 8 domain services)
GATEWAY_URL=http://127.0.0.1:4000
AUTH_SERVICE_URL=http://127.0.0.1:4001
PROFILE_SERVICE_URL=http://127.0.0.1:4002
KYC_SERVICE_URL=http://127.0.0.1:4003
DOCUMENT_SERVICE_URL=http://127.0.0.1:4004
BANKING_SERVICE_URL=http://127.0.0.1:4005
INVESTMENT_SERVICE_URL=http://127.0.0.1:4006
NOTIFICATION_SERVICE_URL=http://127.0.0.1:4007
AUDIT_SERVICE_URL=http://127.0.0.1:4008

# Frontend (customer-web)
NEXT_PUBLIC_API_URL=/api
API_GATEWAY_URL=http://127.0.0.1:4000

# Kafka (leave blank for local dev without event streaming)
KAFKA_BROKERS=127.0.0.1:9092
KAFKA_CLIENT_ID=finboard

# S3 / MinIO object storage (leave blank to use local disk uploads)
S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=finboard-kyc
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_EXPIRY_SECONDS=3600

# Scalar API docs — optional Agent key for "Ask AI" in /docs (free on localhost without key)
# Get a key: https://dashboard.scalar.com/registry
SCALAR_AGENT_KEY=
